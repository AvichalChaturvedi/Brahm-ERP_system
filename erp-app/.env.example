# ============================================================================
# FREE TIER CONFIGURATION - Hardware ERP
# Zero-cost deployment on GitHub Pages + Supabase free tier
# ============================================================================

# REQUIRED: Supabase API Credentials
# Get these from: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# FREE TIER SETTINGS (Default: Safe for $0 cost)
# ============================================================================

# App Environment
VITE_APP_ENV=free-tier

# Deployment settings for GitHub Pages
# For repo: username/hardware-erp → use '/hardware-erp/'
# For user pages (username.github.io) → use '/'
VITE_BASE_URL=/hardware-erp/

# ============================================================================
# COST CONTROL FLAGS (Keep disabled for free tier)
# ============================================================================

# Real-time updates: Disable to save money (use polling instead)
# Set to 'true' to disable realtime, 'false' to enable (costs extra)
VITE_DISABLE_REALTIME=true

# File uploads: Disable to preserve 1GB free storage
# Set to 'true' to disable uploads, 'false' to enable
VITE_DISABLE_FILE_UPLOAD=true

# Email notifications: Disable to avoid external service costs
# Set to 'true' to disable emails, 'false' to enable (costs extra)
VITE_DISABLE_EMAIL=true

# Polling interval in milliseconds (30000 = 30 seconds)
# Lower = more responsive but more API calls
# Higher = fewer API calls but slower updates
# 30000 is safe for free tier
VITE_POLLING_INTERVAL=30000

# ============================================================================
# OPTIONAL: External Integrations (For Phase 2+, leave blank for now)
# ============================================================================

# GitHub integration (phase 2+)
# VITE_GITHUB_TOKEN=your-github-token

# Figma integration (phase 2+)
# VITE_FIGMA_TOKEN=your-figma-token

# Octopart supplier API (phase 3+)
# VITE_OCTOPART_API_KEY=your-octopart-key

# ============================================================================
# NOTES:
# ============================================================================
# - Keep all VITE_DISABLE_* flags set to 'true' for zero-cost deployment
# - Do not enable file uploads unless you're ready to pay for storage
# - Do not enable real-time unless you need instant updates
# - Do not add email notifications until phase 2+
# - All flags starting with VITE_ are safe to expose in frontend code
# - This configuration is free forever for small teams (5-15 users)
# ============================================================================

