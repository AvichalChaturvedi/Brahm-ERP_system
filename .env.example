DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brahmforge"
NEXTAUTH_SECRET="replace-with-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"
STORAGE_PROVIDER="s3"
MAX_UPLOAD_BYTES="52428800"

S3_ENDPOINT="minio"
S3_PORT="9000"
S3_USE_SSL="false"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="brahmforge-files"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"

GROQ_API_KEY=""
OPENROUTER_API_KEY=""
AI_PROVIDER="groq"
DEFAULT_AI_MODEL="llama-3.1-8b-instant"
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
FROM_EMAIL="onboarding@brahmforge.com"

DIGIKEY_CLIENT_ID=""
DIGIKEY_CLIENT_SECRET=""
DIGIKEY_REDIRECT_URI=""
