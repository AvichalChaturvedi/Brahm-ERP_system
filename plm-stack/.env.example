# ============================================
# PLM Stack Environment Configuration
# ============================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# Run: copy .env.example .env
# ============================================

# ============================================
# HOST CONFIGURATION
# ============================================
# Your local network IP address
# Run 'ipconfig' in PowerShell to find this
# Example: 192.168.1.100
HOST_IP=192.168.1.100

# ============================================
# POSTGRESQL DATABASE
# ============================================
# Shared database for InvenTree and Odoo
POSTGRES_DB=plm_db
POSTGRES_USER=plm_admin
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_2024!

# ============================================
# INVERTREE SETTINGS
# ============================================
# Generate a secure key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
INVENTREE_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_SECRET_KEY_RUN_PYTHON_COMMAND

# ============================================
# ODOO SETTINGS
# ============================================
# Master password for Odoo admin access
# This is NOT your user password
ODOO_MASTER_PASSWORD=CHANGE_THIS_SECURE_ODOO_PASSWORD!

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
# For notifications and password resets
# Example for Gmail: Use App Password, not your regular password
# Get app password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_USE_TLS=True
EMAIL_FROM=plm-system@yourcompany.local

# ============================================
# BACKUP SETTINGS
# ============================================
# Automatic backup schedule (cron format)
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
